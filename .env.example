# ===========================
# Database Configuration
# ===========================
# MongoDB connection string - use localhost for development, managed service for production
MONGODB_URI=mongodb://localhost:27017/mhcs

# ===========================
# Authentication
# ===========================
# JWT secret key - must be a strong random string in production (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
# Token expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# Server Configuration
# ===========================
# Environment: development, staging, production
NODE_ENV=development
# Server port
PORT=5000
# Client application URL
CLIENT_URL=http://localhost:5173
# AI Service URL
AI_SERVICE_URL=http://localhost:8001

# ===========================
# Security
# ===========================
# Cookie security settings
COOKIE_SECURE=false
# Session timeout in milliseconds (900000 = 15 minutes)
SESSION_TIMEOUT_MS=900000

# ===========================
# Rate Limiting
# ===========================
# Time window for rate limiting in milliseconds
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window
RATE_LIMIT_MAX=100

# ===========================
# AI Service
# ===========================
AI_SERVICE_PORT=8001

# ===========================
# Logging
# ===========================
# Log level: debug, info, warn, error
LOG_LEVEL=info
