{
  "name": "mhcs",
  "version": "1.0.0",
  "private": true,
  "description": "Mental Health Care System for university students",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "dev:server": "npm --workspace=server run dev",
    "dev:client": "npm --workspace=client run dev",
    "dev:ai": "cd ai-service && python -m uvicorn main:app --reload --port 8001",
    "build": "npm run build --workspaces",
    "build:server": "npm --workspace=server run build",
    "build:client": "npm --workspace=client run build",
    "test": "npm run test --workspaces",
    "test:server": "npm --workspace=server run test",
    "test:client": "npm --workspace=client run test",
    "lint": "npm run lint --workspaces",
    "lint:server": "npm --workspace=server run lint",
    "lint:client": "npm --workspace=client run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\" --ignore-path .gitignore",
    "type-check": "npm run type-check --workspaces",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0"
  }
}
